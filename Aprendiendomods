local function getTargetPart(character)
    if targetPart == "Head" then
        return character:FindFirstChild("Head")
    else
        return character:FindFirstChild("HumanoidRootPart")
    end
end-- Wall Check: Solo apunta si está visible
local function canSee(target)
    local origin = camera.CFrame.Position
    local direction = (target.Position - origin).Unit
    local raycast = workspace:Raycast(origin, direction * 500)
    
    if raycast then
        local hit = raycast.Instance
        if hit:IsDescendantOf(target.Parent) then
            return true
        end
    end
    return false
end-- Hold Key: Aimbot solo mientras mantienes tecla
