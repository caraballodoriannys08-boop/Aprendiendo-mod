local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")
local camera = workspace.CurrentCamera
local uis = game:GetService("UserInputService")
local rs = game:GetService("RunService")

-- ========== ESTADOS ==========
local godmodeActive = false
local speedActive = false
local flyActive = false
local killAuraActive = false
local espActive = false
local autoWinActive = false
local spinbotActive = false
local bodyVel = nil

-- ========== NOTIFICACIONES ==========
local function notify(title, text)
    game:GetService("StarterGui"):SetCore("SendNotification", {Title = title, Text = text, Duration = 2})
end

-- ========== FUNCIONES ==========
local function toggleGodmode()
    godmodeActive = not godmodeActive
    if godmodeActive then
        task.spawn(function()
            while godmodeActive do
                task.wait(0.1)
                humanoid.Health = humanoid.MaxHealth
                humanoid.BreakJointsOnDeath = false
            end
        end)
        notify("✨ Godmode", "ON")
    else
        humanoid.BreakJointsOnDeath = true
        notify("✨ Godmode", "OFF")
    end
end

local function toggleSpeed()
    speedActive = not speedActive
    humanoid.WalkSpeed = speedActive and 32 or 16
    notify("⚡ Velocidad", speedActive and "x2" or "Normal")
end

local function toggleFly()
    flyActive = not flyActive
    if flyActive then
        bodyVel = Instance.new("BodyVelocity")
        bodyVel.MaxForce = Vector3.new(100000, 100000, 100000)
        bodyVel.Parent = rootPart
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
        local conn
        conn = rs.RenderStepped:Connect(function()
            if not flyActive then conn:Disconnect() return end
            local move = Vector3.new()
            if uis:IsKeyDown(Enum.KeyCode.W) then move = move + Vector3.new(0,0,-1) end
            if uis:IsKeyDown(Enum.KeyCode.S) then move = move + Vector3.new(0,0,1) end
            if uis:IsKeyDown(Enum.KeyCode.A) then move = move + Vector3.new(-1,0,0) end
            if uis:IsKeyDown(Enum.KeyCode.D) then move = move + Vector3.new(1,0,0) end
            if uis:IsKeyDown(Enum.KeyCode.Q) then move = move + Vector3.new(0,1,0) end
            if uis:IsKeyDown(Enum.KeyCode.E) then move = move + Vector3.new(0,-1,0) end
            bodyVel.Velocity = move.Magnitude > 0 and rootPart.CFrame:VectorToWorldSpace(move.Unit * 150) or Vector3.new(0,0,0)
        end)
        notify("🕊️ Fly", "ON")
    else
        if bodyVel then bodyVel:Destroy() end
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
        notify("🕊️ Fly", "OFF")
    end
end

local function toggleKillAura()
    killAuraActive = not killAuraActive
    if killAuraActive then
        task.spawn(function()
            while killAuraActive do
                task.wait(0.2)
                for _, other in pairs(game.Players:GetPlayers()) do
                    if other ~= player and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
                        local target = other.Character.HumanoidRootPart
                        if (rootPart.Position - target.Position).Magnitude < 30 then
                            rootPart.CFrame = target.CFrame
                        end
                    end
                end
            end
        end)
        notify("⚔️ Kill Aura", "ON")
    else
        notify("⚔️ Kill Aura", "OFF")
    end
end

local function killAll()
    for _, other in pairs(game.Players:GetPlayers()) do
        if other ~= player and other.Character and other.Character:FindFirstChild("Humanoid") then
            other.Character.Humanoid.Health = 0
        end
    end
    notify("💀 Kill All", "Todos eliminados")
end

local function toggleESP()
    espActive = not espActive
    if espActive then
        task.spawn(function()
            while espActive do
                task.wait(0.5)
                for _, other in pairs(game.Players:GetPlayers()) do
                    if other ~= player and other.Character and not other.Character:FindFirstChild("ESP_Highlight") then
                        local hl = Instance.new("Highlight")
                        hl.Name = "ESP_Highlight"
                        hl.FillColor = Color3.fromRGB(255,0,0)
                        hl.FillTransparency = 0.5
                        hl.Parent = other.Character
                    end
                end
            end
        end)
        notify("👁️ ESP", "ON")
    else
        for _, v in pairs(workspace:GetDescendants()) do
            if v.Name == "ESP_Highlight" then v:Destroy() end
        end
        notify("👁️ ESP", "OFF")
    end
end

local function toggleAutoWin()
    autoWinActive = not autoWinActive
    if autoWinActive then
        task.spawn(function()
            while autoWinActive do
                task.wait(0.3)
                for _, v in pairs(workspace:GetDescendants()) do
                    local name = v.Name:lower()
                    if name:find("win") or name:find("finish") then
                        local cd = v:FindFirstChild("ClickDetector")
                        if cd then fireclickdetector(cd) end
                        rootPart.CFrame = v:GetPivot()
                    end
                end
            end
        end)
        notify("🏆 Auto Win", "ON")
    else
        notify("🏆 Auto Win", "OFF")
    end
end

local function toggleSpinbot()
    spinbotActive = not spinbotActive
    if spinbotActive then
        task.spawn(function()
            while spinbotActive do
                task.wait()
                rootPart.CFrame = rootPart.CFrame * CFrame.Angles(0, math.rad(100), 0)
            end
        end)
        notify("🔄 Spinbot", "ON")
    else
        notify("🔄 Spinbot", "OFF")
    end
end

local function teleportToWin()
    for _, v in pairs(workspace:GetDescendants()) do
        local name = v.Name:lower()
        if name:find("win") or name:find("finish") then
            rootPart.CFrame = v:GetPivot()
            notify("🏁 Teleport", "Meta")
            break
        end
    end
end

